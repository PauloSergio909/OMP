# ══════════════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE — FleetMaster
# ══════════════════════════════════════════════════════════════
# COMO USAR:
# 1. Copie este arquivo: cp .env.example .env
# 2. Edite o .env com suas credenciais reais
# 3. NUNCA suba o .env para o Git (já está no .gitignore)
#
# O .env.example vai pro Git como "modelo" para outros devs.
# O .env real fica só na sua máquina (ou no servidor de produção).

# ─── BANCO DE DADOS ───────────────────────────────────────────
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL=postgresql://fleetmaster:fleetmaster123@localhost:5432/fleetmaster_dev

# ─── REDIS ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AUTENTICAÇÃO JWT ─────────────────────────────────────────
# IMPORTANTE: em produção, use chaves aleatórias longas (64+ chars)
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=minha-chave-secreta-desenvolvimento-local
JWT_REFRESH_SECRET=minha-chave-refresh-desenvolvimento-local

# Tempo de expiração dos tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SERVIDOR ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── FRONT-END ────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
