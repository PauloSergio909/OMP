# ══════════════════════════════════════════════════════════════
# FleetMaster API — variáveis de ambiente
# Copie para .env e preencha os valores antes de iniciar
# ══════════════════════════════════════════════════════════════

# ─── Servidor ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Banco de dados (PostgreSQL) ──────────────────────────────
# Usuário/senha/banco padrão definidos no docker-compose.yml
DATABASE_URL=postgresql://fleetmaster:fleetmaster123@localhost:5432/fleetmaster_dev

# ─── Cache (Redis) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (mude o segredo em produção!) ───────────────────────
JWT_SECRET=sua-chave-secreta-mude-em-producao-123
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
# Deixe em branco para aceitar qualquer origem (desenvolvimento)
# Em produção: ALLOWED_ORIGIN=https://seudominio.com
# ALLOWED_ORIGIN=

# ─── E-mail (alertas automáticos — opcional) ──────────────────
# Se não configurado, o job de alertas roda mas não envia e-mails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seuemail@gmail.com
# SMTP_PASS=sua-senha-de-app
# SMTP_FROM=FleetMaster <noreply@seudominio.com>
# ALERTAS_EMAIL_DEST=gestor@empresa.com
# ALERTAS_INTERVALO_HORAS=24
